class shape:
    def area(self):
        print("Area of the shape")
class Circle(shape):
    def __init__(self,radius):
        self.radius=radius
    def area(self):
        print("Area of the shape:",self.radius*3.14)
class rectangle(shape):
    def __init__(self,length,breadth):
        self.length=length
        self.breadth=breadth
    def area(self):
         print("Area of the shape",self.length*self.breadth)
c=Circle(6)
c.area()
r=rectangle(2,4)
r.area()
